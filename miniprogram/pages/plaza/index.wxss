.plaza {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero {
  overflow: hidden;
  border-radius: 36rpx;
  padding: 44rpx 36rpx;
  background: linear-gradient(135deg, #0f172a 0%, #164e63 58%, #0f766e 100%);
  color: #ffffff;
  box-shadow: 0 28rpx 80rpx rgba(15, 118, 110, 0.24);
}

.hero__eyebrow {
  color: #fde68a;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.hero__title {
  margin-top: 28rpx;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1;
}

.hero__copy {
  margin-top: 24rpx;
  color: #dbeafe;
  font-size: 28rpx;
  line-height: 1.75;
}

.hero__stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 34rpx;
}

.hero__stats view {
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero__stats text:first-child {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
}

.hero__stats text:last-child {
  display: block;
  margin-top: 6rpx;
  color: #cbd5e1;
  font-size: 22rpx;
}

.toolbar {
  display: grid;
  grid-template-columns: 1fr 120rpx;
  gap: 16rpx;
  padding: 18rpx;
}

.toolbar__input {
  height: 76rpx;
  border-radius: 22rpx;
  padding: 0 22rpx;
  background: #f1f5f9;
  color: #0f172a;
  font-size: 26rpx;
}

.toolbar__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
