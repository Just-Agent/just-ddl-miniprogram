<view class="page safe-bottom plaza">
  <view class="hero">
    <view class="hero__eyebrow">JUST-DDL NETWORK</view>
    <view class="hero__title">主题广场</view>
    <view class="hero__copy">把分散在各个仓库的截止日整理成可以订阅、追踪和复用的专题网络。</view>
    <view class="hero__stats">
      <view><text>{{stats.topics}}</text><text>专题</text></view>
      <view><text>{{stats.items}}</text><text>DDL 条目</text></view>
      <view><text>{{favoriteTopics.length}}</text><text>已收藏</text></view>
    </view>
  </view>

  <view class="toolbar card">
    <input class="toolbar__input" placeholder="搜索专题、标签、分类" value="{{query}}" bindinput="handleSearch" />
    <button class="toolbar__btn" bindtap="refresh">刷新</button>
  </view>

  <view wx:if="{{filteredTopics.length}}" class="topic-list">
    <topic-card
      wx:for="{{filteredTopics}}"
      wx:key="id"
      topic="{{item}}"
      favorite="{{item.favorite}}"
      bind:open="openTopic"
      bind:togglefavorite="toggleTopic"
      bind:repo="copyRepo"
    />
  </view>
  <empty-state
    wx:else
    title="{{loading ? '正在加载专题' : '没有匹配的专题'}}"
    description="可以换一个关键词，或刷新 Hub 数据。"
    action="刷新数据"
    bind:action="refresh"
  />
</view>
