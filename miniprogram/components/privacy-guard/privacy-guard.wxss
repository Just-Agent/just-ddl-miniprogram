.privacy {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.38);
}

.privacy__panel {
  width: 100%;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}

.privacy__title {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
}

.privacy__body {
  margin-top: 16rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.8;
}

.privacy__actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 28rpx;
}

.privacy__link,
.privacy__ok {
  border-radius: 22rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.privacy__link {
  border: 1rpx solid #dbe7f3;
  color: #0f172a;
}

.privacy__ok {
  background: #0f766e;
  color: #ffffff;
}
