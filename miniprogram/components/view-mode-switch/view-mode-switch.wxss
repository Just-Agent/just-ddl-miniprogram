.switch {
  display: inline-flex;
  overflow: hidden;
  border: 1rpx solid #dbe7f3;
  border-radius: 999rpx;
  background: #ffffff;
}

.switch__item {
  padding: 14rpx 22rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 900;
}

.switch__item.is-active {
  background: #e0f2fe;
  color: #0284c7;
}
