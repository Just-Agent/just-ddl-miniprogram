.source {
  position: relative;
  overflow: hidden;
  height: 188rpx;
  border-radius: 26rpx;
  background: #0f172a;
}

.source__img,
.source__fallback {
  width: 100%;
  height: 100%;
}

.source__fallback {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 28rpx;
  color: #ffffff;
}

.source__fallback text:first-child {
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.source__fallback text:last-child {
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.source__shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(2, 6, 23, 0.12), rgba(2, 6, 23, 0.66));
}

.source__meta {
  position: absolute;
  left: 20rpx;
  right: 74rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.source__mode,
.source__label {
  overflow: hidden;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source__mode {
  flex: none;
  background: rgba(15, 23, 42, 0.78);
  color: #ffffff;
}

.source__label {
  flex: 1;
  background: #ffffff;
  color: #0f172a;
}

.source__open {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}
