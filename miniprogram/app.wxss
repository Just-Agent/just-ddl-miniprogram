page {
  background: #f8fafc;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

view, text, button, input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
}

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.card {
  border: 1rpx solid #dbe7f3;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.06);
}

.muted {
  color: #64748b;
}

.mono {
  font-variant-numeric: tabular-nums;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.primary-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  padding: 20rpx 28rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.ghost-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dbe7f3;
  border-radius: 22rpx;
  padding: 18rpx 24rpx;
  background: #ffffff;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 900;
}
