.detail,
.sections {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.topic-hero {
  padding: 32rpx;
}

.topic-hero__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.topic-hero__eyebrow {
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.topic-hero__title {
  margin-top: 10rpx;
  color: #020617;
  font-size: 54rpx;
  font-weight: 900;
}

.topic-hero__star {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid #dbe7f3;
  border-radius: 50%;
  color: #94a3b8;
  font-size: 34rpx;
}

.topic-hero__star.is-active {
  border-color: #fde68a;
  background: #fef3c7;
  color: #f59e0b;
}

.topic-hero__copy {
  margin-top: 20rpx;
  color: #475569;
  font-size: 28rpx;
  line-height: 1.75;
}

.topic-hero__stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.topic-hero__stats view {
  border: 1rpx solid #dbe7f3;
  border-radius: 22rpx;
  padding: 18rpx;
  background: #f8fafc;
}

.topic-hero__stats text:first-child {
  display: block;
  color: #020617;
  font-size: 36rpx;
  font-weight: 900;
}

.topic-hero__stats text:last-child {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.topic-hero__actions {
  margin-top: 24rpx;
}

.topic-hero__actions button {
  display: inline-flex;
  border-radius: 22rpx;
  padding: 18rpx 24rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.controls {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 18rpx;
}
